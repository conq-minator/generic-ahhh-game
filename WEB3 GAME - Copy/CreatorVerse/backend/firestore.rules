rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Rules for the 'guilds' collection
    match /guilds/{guildId} {
      // Allow anyone to read the guild data (required for the frontend leaderboard)
      allow read: if true;
      
      // Allow creating a new guild as long as they provide a valid name and don't overwrite an existing one
      allow create: if true 
                    && request.resource.data.keys().hasAll(['name', 'members', 'donated', 'emoji'])
                    && request.resource.data.name is string;
                    
      // Allow updating a guild (e.g., when someone joins and the members count increases)
      allow update: if true;
      
      // Prevent deleting guilds for safety
      allow delete: if false;
    }
    
    // Default rule: block everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
